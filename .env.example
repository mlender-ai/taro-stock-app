# FRED(미 연준 공식 데이터, DATA_ENGINE_STRATEGY C-2). 없어도 키리스(fredgraph.csv)로 동작.
# 키 발급(무료): https://fred.stlouisfed.org/docs/api/api_key.html → 설정 시 공식 JSON API 로 업그레이드.
FRED_API_KEY=""
# 한국투자증권 KIS Open API — 투자자 매매동향(개인·외국인·기관). 수급 정밀화(개인 포함).
# 무료. 발급: https://apiportal.koreainvestment.com → 계좌 연결 → 앱키/시크릿. 둘 다 설정 시 KIS 경로 활성(없으면 네이버 폴백).
KIS_APP_KEY=""
KIS_APP_SECRET=""
RESEARCH_PUBLISHED_SNAPSHOT_URL="https://raw.githubusercontent.com/mlender-ai/auto-trading-bot/main/generated/research/latest.json"
NEWSLETTER_TO=""
NEWSLETTER_FROM=""
RESEND_API_KEY=""
OPENAI_API_KEY=""
OPENAI_MODEL=""
OPENAI_BASE_URL=""

# ─── Tarot 앱 전용 ────────────────────────────────────────────────────────────
TAROT_API_SECRET="change-me"              # JWT HMAC 시크릿(32자+). prod 미설정 시 fail-closed throw. `openssl rand -base64 48`

# 소셜 로그인 (서버 사이드 토큰 검증)
APPLE_CLIENT_ID=""                        # Apple Sign In: Services ID
APPLE_TEAM_ID=""
APPLE_KEY_ID=""
APPLE_PRIVATE_KEY=""                      # .p8 파일 내용 (줄바꿈 \n 처리)
GOOGLE_CLIENT_ID_IOS=""                   # Google Sign In: iOS Client ID
GOOGLE_CLIENT_ID_ANDROID=""

# 결제 (서버 사이드 영수증 검증)
REVENUECAT_SECRET_API_KEY=""              # RevenueCat → Project Settings → API Keys → Secret
APPLE_SHARED_SECRET=""                    # App Store Connect → 공유 암호
GOOGLE_SERVICE_ACCOUNT_KEY=""             # GCP 서비스 계정 JSON (base64)

# 광고 (App ID = 앱 레벨, Unit ID = 광고 단위)
REWARD_NONCE_SECRET="change-me"           # 리워드 광고 nonce HMAC 시크릿(32자+). prod 미설정 시 fail-closed throw
ADMOB_APP_ID_IOS=""
ADMOB_APP_ID_ANDROID=""
ADMOB_BANNER_ID_IOS=""
ADMOB_BANNER_ID_ANDROID=""
ADMOB_REWARDED_ID_IOS=""
ADMOB_REWARDED_ID_ANDROID=""

# 푸시 알림
EXPO_PUSH_ACCESS_TOKEN=""                 # Expo Push API 토큰

# 카카오 로그인
EXPO_PUBLIC_KAKAO_APP_KEY=""              # Kakao Developers → 앱 키 → REST API 키

# 네이버 로그인
EXPO_PUBLIC_NAVER_CLIENT_ID=""            # Naver Developers → 애플리케이션 → Client ID
EXPO_PUBLIC_NAVER_CLIENT_SECRET=""        # Naver Developers → 애플리케이션 → Client Secret

# ─── Slack Agent Bot (Phase 2) ────────────────────────────────────────────────
SLACK_BOT_TOKEN=""                        # Slack Bot User OAuth Token (xoxb-...)
SLACK_SIGNING_SECRET=""                   # Slack App → Basic Information → Signing Secret
GITHUB_PAT=""                             # Fine-grained PAT (repo + workflow 스코프)
GITHUB_REPO="mlender-ai/taro-stock-app"   # GitHub 레포 (owner/repo)

# ─── FOMO 롤링 배너 거시지수 (#480) ──────────────────────────────────────────
# Twelve Data 무료키(800req/day) — 배너 macro 1차 소스. Yahoo egress 차단 회피용.
# 미설정 시 자동으로 Yahoo chart 폴백(현 동작 유지). Vercel env 에만 넣으면 자동 격상.
# 발급: https://twelvedata.com → Sign up → Dashboard → API Key
TWELVE_DATA_API_KEY=""

# ─── AI Agent Chat (Phase 3) ─────────────────────────────────────────────────
AI_API_URL=""                             # AI API 엔드포인트 (예: https://models.github.ai/inference/chat/completions)
AI_API_KEY=""                             # AI API 키
AI_MODEL="openai/gpt-4o"                 # AI 모델 (provider/model 형식)

# ─── FOMO 방향 전환 Feature Flags (docs/PIVOT_FEED_FIRST.md) ─────────────────
# 기본값은 packages/fomo-core/src/features.ts 코드 상수. 환경변수는 덮어쓰기용.
# 웹(fomo-web)=NEXT_PUBLIC_, 네이티브(fomo-club)=EXPO_PUBLIC_ 접두사 동일 키.
EXPO_PUBLIC_FEATURE_EMOTION_VOTE="false"      # 감정 선택/투표 (숨김)
EXPO_PUBLIC_FEATURE_EMOTION_JOURNAL="false"   # 감정 기록(조각/한마디) (숨김)
EXPO_PUBLIC_FEATURE_EMOTION_CALENDAR="false"  # 감정 캘린더 (숨김)
EXPO_PUBLIC_FEATURE_HISTORY_TAB="false"       # 하단 기록 탭 (숨김)
EXPO_PUBLIC_FEATURE_FEED_EMOTION_TABS="true"  # 신규 감정 카테고리 피드
