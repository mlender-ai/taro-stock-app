{
  "name": "fomo-club",
  "private": true,
  "engines": {
    "node": ">=20.9.0"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "build:api": "npm --workspace @fomo/legacy-paper-api run build",
    "build:shared": "npm --workspace @fomo/shared run build",
    "build:web": "npm --workspace @fomo/backend run build",
    "ci": "npm run lint && npm run typecheck && npm run build",
    "dev": "tsx scripts/dev.ts",
    "dev:api": "npm --workspace @fomo/legacy-paper-api run dev",
    "dev:web": "npm --workspace @fomo/backend run dev",
    "clean:web": "npm --workspace @fomo/backend run clean",
    "reset:web": "npm run clean:web && npm run dev:web",
    "dev:worker": "npm --workspace @fomo/legacy-paper-api run worker:dev",
    "lint": "npm run lint --workspaces --if-present",
    "lint:api": "npm --workspace @fomo/legacy-paper-api run lint",
    "lint:shared": "npm --workspace @fomo/shared run lint",
    "lint:web": "npm --workspace @fomo/backend run lint",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "typecheck:api": "npm --workspace @fomo/legacy-paper-api run typecheck",
    "typecheck:shared": "npm --workspace @fomo/shared run typecheck",
    "typecheck:web": "npm --workspace @fomo/backend run typecheck",
    "typecheck:fomo-core": "npm --workspace @fomo/core run typecheck",
    "build:fomo-core": "npm --workspace @fomo/core run build",
    "dev:fomo-club": "npm --workspace fomo-club run start",
    "typecheck:fomo-club": "npm --workspace fomo-club run typecheck",
    "dev:fomo-web": "npm --workspace @fomo/web run dev",
    "build:fomo-web": "npm --workspace @fomo/web run build",
    "typecheck:fomo-web": "npm --workspace @fomo/web run typecheck",
    "paper:status": "tsx scripts/paper-status.ts",
    "qa:screenshot": "tsx scripts/qa-screenshot.ts",
    "research:generate": "tsx scripts/research-pipeline.ts",
    "research:issues": "tsx scripts/research-agent-issues.ts",
    "research:newsletter": "tsx scripts/research-newsletter.ts",
    "agent:tooling-scout": "tsx scripts/agent-tooling-scout.ts",
    "fomo:index": "tsx scripts/fomo-index-pipeline.ts",
    "keywords:generate": "tsx scripts/keywords-generate.ts",
    "warm:insights": "tsx scripts/warm-insights.ts",
    "supply:collect": "tsx scripts/supply-demand-collect.ts",
    "metrics:fomo": "tsx scripts/fomo-product-metrics.ts",
    "quality:fomo": "tsx scripts/fomo-quality-report.ts",
    "guard:discovery": "tsx scripts/discovery-regression-gate.ts",
    "guard:product": "npm run guard:discovery",
    "eval:understanding": "tsx scripts/eval-understanding.ts",
    "eval:understanding:live": "tsx scripts/eval-understanding-live.ts",
    "prisma:generate": "prisma generate",
    "prisma:migrate:dev": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:seed": "tsx prisma/seed.ts",
    "prisma:studio": "prisma studio",
    "telegram:test": "tsx scripts/telegram-test.ts",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "prisma": "^5.22.0",
    "react": "^19.2.7",
    "tsx": "^4.22.4",
    "typescript": "^5.7.2",
    "vitest": "^4.1.9"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@react-native-seoul/kakao-login": "^5.4.2",
    "@react-native-seoul/naver-login": "^4.2.4",
    "expo-secure-store": "^55.0.14"
  }
}
