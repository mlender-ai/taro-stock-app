generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum BotStatus {
  RUNNING
  STOPPED
  DEGRADED
}

enum StrategyStatus {
  ACTIVE
  PAUSED
  DISABLED
}

enum StrategyRunStatus {
  SIGNAL
  NO_SIGNAL
  ERROR
  SKIPPED
}

enum PositionStatus {
  OPEN
  CLOSED
}

enum OrderRole {
  MAKER
  TAKER
}

enum TradeAction {
  BUY
  SELL
  CLOSE
  STOP_LOSS
  TAKE_PROFIT
}

enum AlertType {
  ENTRY
  EXIT
  STOP_LOSS
  TAKE_PROFIT
  ERROR
  INFO
  RESTART
}

enum AlertStatus {
  PENDING
  SENT
  FAILED
}

enum SystemLogLevel {
  INFO
  WARN
  ERROR
}

enum StrategySessionStatus {
  ACTIVE
  ARCHIVED
}

enum NewsletterDigestStatus {
  DRAFT
  GENERATED
  SENT
  FAILED
}

// ─── Tarot 앱 전용 enum ───────────────────────────────────────────────────────

enum TarotAuthProvider {
  APPLE
  GOOGLE
  KAKAO
  NAVER
}

enum TarotMembershipStatus {
  FREE
  PRO
}

enum TarotSpreadType {
  SINGLE
  THREE_CARD
}

enum TarotMarket {
  US
  KR
}

enum TarotInterpretationSource {
  LLM
  CACHE
  FALLBACK
}

enum TarotCreditReason {
  SIGNUP_BONUS
  PURCHASE
  REWARD_AD
  REWARD_SHARE
  DRAW_SINGLE
  DRAW_THREE
  REFUND
  STREAK_REWARD
}

enum TarotDisclaimerVersion {
  V1
}

enum TarotFeedbackRating {
  ONE
  TWO
  THREE
  FOUR
  FIVE
}

enum TarotReportStatus {
  PENDING
  REVIEWED
  RESOLVED
}

enum TarotCardStatus {
  ACTIVE
  INACTIVE
}

model User {
  id                 String                  @id @default(cuid())
  email              String?                 @unique
  passwordHash       String?
  displayName        String?
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt
  // 타로 앱 전용 필드
  authProvider       TarotAuthProvider?
  authProviderId     String?
  membershipStatus   TarotMembershipStatus   @default(FREE)
  pushToken          String?
  disclaimerVersion  TarotDisclaimerVersion?
  disclaimerAgreedAt DateTime?
  // 연속 로그인 스트릭
  streakCount        Int                     @default(0)
  streakLastDate     DateTime?
  // 관계
  bots               Bot[]
  researchProfile    ResearchProfile?
  agentThreads       AgentMeetingThread[]
  creditLedger       TarotCreditLedger[]
  drawHistory        TarotDrawHistory[]
  favorites          TarotFavorite[]
  feedbacks          TarotFeedback[]
  reports            TarotReport[]
  cardCollection     TarotCardCollection[]
  analyticsEvents    TarotAnalyticsEvent[]

  @@unique([authProvider, authProviderId])
  @@index([authProvider, authProviderId])
}

model Bot {
  id                     String            @id @default(cuid())
  userId                 String?
  name                   String
  mode                   String            @default("paper")
  status                 BotStatus         @default(STOPPED)
  exchangeKey            String            @default("mock-binance-futures")
  baseAsset              String            @default("USDT")
  paperBalance           Float             @default(10000)
  reservedBalance        Float             @default(0)
  makerFeeRate           Float             @default(0.0002)
  takerFeeRate           Float             @default(0.0005)
  entryOrderRole         OrderRole         @default(TAKER)
  exitOrderRole          OrderRole         @default(TAKER)
  slippageBps            Float             @default(4)
  heartbeatAt            DateTime?
  lastErrorAt            DateTime?
  lastDailyReportSentAt  DateTime?
  lastWeeklyReportSentAt DateTime?
  metadata               Json?
  createdAt              DateTime          @default(now())
  updatedAt              DateTime          @updatedAt
  user                   User?             @relation(fields: [userId], references: [id])
  strategies             Strategy[]
  sessions               StrategySession[]
  strategyRuns           StrategyRun[]
  positions              Position[]
  trades                 Trade[]
  alerts                 Alert[]
  dailySummaries         DailySummary[]
  systemLogs             SystemLog[]
}

model Strategy {
  id              String         @id @default(cuid())
  botId           String
  key             String
  name            String
  description     String?
  status          StrategyStatus @default(PAUSED)
  symbol          String
  timeframe       String         @default("15m")
  config          Json
  lastEvaluatedAt DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  bot             Bot            @relation(fields: [botId], references: [id])
  runs            StrategyRun[]
  positions       Position[]
  trades          Trade[]
  alerts          Alert[]

  @@unique([botId, key])
}

model StrategySession {
  id             String                @id @default(cuid())
  botId          String
  name           String
  runLabel       String
  status         StrategySessionStatus @default(ACTIVE)
  notes          String?
  configSnapshot Json?
  startedAt      DateTime              @default(now())
  endedAt        DateTime?
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt
  bot            Bot                   @relation(fields: [botId], references: [id])
  strategyRuns   StrategyRun[]
  positions      Position[]
  trades         Trade[]
  alerts         Alert[]
  dailySummaries DailySummary[]

  @@index([botId, status, startedAt])
}

model DailySummary {
  id                     String           @id @default(cuid())
  botId                  String
  sessionId              String?
  scopeKey               String           @unique
  dateKey                String
  timezone               String
  sessionName            String?
  runLabel               String?
  tradeCount             Int              @default(0)
  closedPositionCount    Int              @default(0)
  winCount               Int              @default(0)
  lossCount              Int              @default(0)
  grossPnl               Float            @default(0)
  netPnl                 Float            @default(0)
  totalFees              Float            @default(0)
  totalWinningPnl        Float            @default(0)
  totalLosingPnl         Float            @default(0)
  bestTrade              Float            @default(0)
  worstTrade             Float            @default(0)
  strategyPerformance    Json
  entryReasonPerformance Json
  exitReasonPerformance  Json
  createdAt              DateTime         @default(now())
  updatedAt              DateTime         @updatedAt
  bot                    Bot              @relation(fields: [botId], references: [id])
  session                StrategySession? @relation(fields: [sessionId], references: [id])

  @@index([botId, dateKey])
  @@index([sessionId, dateKey])
}

model StrategyRun {
  id                String            @id @default(cuid())
  botId             String
  strategyId        String
  sessionId         String?
  runLabel          String?
  symbol            String
  timeframe         String
  status            StrategyRunStatus
  signalType        String
  price             Float?
  primaryReasonCode String?
  primaryReasonText String?
  reasonsText       String?
  reasons           Json?
  indicators        Json?
  errorMessage      String?
  executedAt        DateTime          @default(now())
  bot               Bot               @relation(fields: [botId], references: [id])
  strategy          Strategy          @relation(fields: [strategyId], references: [id])
  session           StrategySession?  @relation(fields: [sessionId], references: [id])

  @@index([sessionId, executedAt])
}

model Position {
  id              String           @id @default(cuid())
  botId           String
  strategyId      String?
  sessionId       String?
  symbol          String
  side            String           @default("LONG")
  status          PositionStatus   @default(OPEN)
  quantity        Float
  entryPrice      Float
  exitPrice       Float?
  entryValue      Float
  exitValue       Float?
  realizedPnl     Float            @default(0)
  unrealizedPnl   Float            @default(0)
  feesPaid        Float            @default(0)
  openedAt        DateTime         @default(now())
  closedAt        DateTime?
  entryReasonCode String
  entryReasonText String
  entryReasonMeta Json
  exitReasonCode  String?
  exitReasonText  String?
  exitReasonMeta  Json?
  bot             Bot              @relation(fields: [botId], references: [id])
  strategy        Strategy?        @relation(fields: [strategyId], references: [id])
  session         StrategySession? @relation(fields: [sessionId], references: [id])
  trades          Trade[]

  @@index([botId, symbol, status])
  @@index([sessionId, status])
}

model Trade {
  id              String           @id @default(cuid())
  botId           String
  strategyId      String?
  positionId      String?
  sessionId       String?
  symbol          String
  action          TradeAction
  side            String           @default("LONG")
  quantity        Float
  price           Float
  notional        Float
  orderRole       OrderRole
  feeRate         Float
  slippageBps     Float            @default(0)
  fee             Float            @default(0)
  grossPnl        Float            @default(0)
  realizedPnl     Float            @default(0)
  reasonCode      String
  reasonText      String
  reasonMeta      Json
  executedAt      DateTime         @default(now())
  externalOrderId String?
  bot             Bot              @relation(fields: [botId], references: [id])
  strategy        Strategy?        @relation(fields: [strategyId], references: [id])
  position        Position?        @relation(fields: [positionId], references: [id])
  session         StrategySession? @relation(fields: [sessionId], references: [id])

  @@index([botId, executedAt])
  @@index([sessionId, executedAt])
}

model Alert {
  id         String           @id @default(cuid())
  botId      String
  strategyId String?
  sessionId  String?
  type       AlertType
  status     AlertStatus      @default(PENDING)
  title      String
  message    String
  payload    Json?
  sentAt     DateTime?
  createdAt  DateTime         @default(now())
  bot        Bot              @relation(fields: [botId], references: [id])
  strategy   Strategy?        @relation(fields: [strategyId], references: [id])
  session    StrategySession? @relation(fields: [sessionId], references: [id])
}

model MarketCandle {
  id          String   @id @default(cuid())
  exchangeKey String
  symbol      String
  timeframe   String
  openTime    DateTime
  closeTime   DateTime
  open        Float
  high        Float
  low         Float
  close       Float
  volume      Float
  createdAt   DateTime @default(now())

  @@unique([exchangeKey, symbol, timeframe, openTime])
  @@index([symbol, timeframe, openTime])
}

model SystemLog {
  id        String         @id @default(cuid())
  botId     String?
  level     SystemLogLevel
  source    String
  message   String
  context   Json?
  createdAt DateTime       @default(now())
  bot       Bot?           @relation(fields: [botId], references: [id])

  @@index([createdAt])
}

model ResearchProfile {
  id                String             @id @default(cuid())
  userId            String             @unique
  preferredSectors  Json
  preferredTickers  Json
  newsletterEnabled Boolean            @default(true)
  newsletterEmail   String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  user              User               @relation(fields: [userId], references: [id])
  newsletters       NewsletterDigest[]
}

model ResearchNews {
  id              String   @id @default(cuid())
  title           String
  summary         String
  source          String?
  sectorTag       String
  tickerTags      Json
  importanceScore Float    @default(0)
  analysis        String
  recommendation  String
  publishedAt     DateTime
  metadata        Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([sectorTag, importanceScore])
  @@index([publishedAt])
}

model TickerInsight {
  id                String   @id @default(cuid())
  ticker            String
  company           String?
  sectorTag         String
  importanceScore   Float    @default(0)
  summary           String
  technicalAnalysis String
  patternAnalysis   Json
  marketContext     String
  recommendation    String
  linkedNewsIds     Json
  generatedAt       DateTime @default(now())
  metadata          Json?

  @@index([ticker, generatedAt])
  @@index([sectorTag, importanceScore])
}

model NewsletterDigest {
  id           String                 @id @default(cuid())
  profileId    String?
  cadence      String                 @default("daily")
  status       NewsletterDigestStatus @default(GENERATED)
  subject      String
  previewText  String
  payload      Json
  htmlBody     String?
  textBody     String?
  generatedAt  DateTime               @default(now())
  scheduledFor DateTime?
  sentAt       DateTime?
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt
  profile      ResearchProfile?       @relation(fields: [profileId], references: [id])

  @@index([generatedAt])
  @@index([status, scheduledFor])
}

model AgentMeetingThread {
  id         String                @id @default(cuid())
  userId     String?
  topic      String
  objective  String
  nextAction String
  context    Json?
  createdAt  DateTime              @default(now())
  updatedAt  DateTime              @updatedAt
  user       User?                 @relation(fields: [userId], references: [id])
  messages   AgentMeetingMessage[]

  @@index([userId, createdAt])
}

model AgentMeetingMessage {
  id         String             @id @default(cuid())
  threadId   String
  role       String
  author     String
  content    String
  references Json?
  position   Int
  createdAt  DateTime           @default(now())
  thread     AgentMeetingThread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@unique([threadId, position])
  @@index([threadId, createdAt])
}

// ─── Tarot 앱 전용 모델 ───────────────────────────────────────────────────────

// 타로 카드 메타데이터 (어드민이 관리)
model TarotCard {
  id               String                 @id
  name             String
  nameKo           String
  arcana           String                 @default("major")
  number           Int
  keywords         Json
  keywordsKo       Json
  meaningUpright   String
  meaningReversed  String
  imageUrl         String
  toneGuide        String
  status           TarotCardStatus        @default(ACTIVE)
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt
  drawHistoryCards TarotDrawHistoryCard[]
  collections      TarotCardCollection[]
}

// 크레딧(뽑기권) 원장 — insert-only, 잔액은 SUM(amount)로 계산
model TarotCreditLedger {
  id          String            @id @default(cuid())
  userId      String
  amount      Int // 양수: 충전, 음수: 차감
  reason      TarotCreditReason
  referenceId String? // 결제 ID, 광고 세션 ID 등
  createdAt   DateTime          @default(now())
  user        User              @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
}

// 뽑기 기록
model TarotDrawHistory {
  id             String                    @id @default(cuid())
  userId         String
  ticker         String
  market         TarotMarket
  spread         TarotSpreadType
  headline       String
  summary        String
  detail         String
  source         TarotInterpretationSource
  idempotencyKey String                    @unique
  creditCost     Int
  cacheKey       String?
  createdAt      DateTime                  @default(now())
  user           User                      @relation(fields: [userId], references: [id])
  cards          TarotDrawHistoryCard[]
  feedbacks      TarotFeedback[]
  reports        TarotReport[]

  @@index([userId, createdAt])
  @@index([ticker, createdAt])
}

// 뽑기 결과에 포함된 카드 목록 (1장 또는 3장)
model TarotDrawHistoryCard {
  id          String           @id @default(cuid())
  drawId      String
  cardId      String
  orientation String // "upright" | "reversed"
  slot        String? // "past" | "present" | "future" (3장 스프레드)
  position    Int // 순서
  draw        TarotDrawHistory @relation(fields: [drawId], references: [id], onDelete: Cascade)
  card        TarotCard        @relation(fields: [cardId], references: [id])

  @@index([drawId])
}

// 관심 종목/섹터 즐겨찾기
model TarotFavorite {
  id           String      @id @default(cuid())
  userId       String
  ticker       String
  market       TarotMarket
  label        String? // 표시명 (예: "삼성전자")
  alertEnabled Boolean     @default(false)
  createdAt    DateTime    @default(now())
  user         User        @relation(fields: [userId], references: [id])

  @@unique([userId, ticker])
  @@index([userId])
}

// 해석 피드백 (만족도)
model TarotFeedback {
  id        String              @id @default(cuid())
  userId    String
  drawId    String
  rating    TarotFeedbackRating
  comment   String?
  createdAt DateTime            @default(now())
  user      User                @relation(fields: [userId], references: [id])
  draw      TarotDrawHistory    @relation(fields: [drawId], references: [id])

  @@unique([userId, drawId])
  @@index([drawId])
}

// 부적절한 콘텐츠 신고
model TarotReport {
  id        String            @id @default(cuid())
  userId    String
  drawId    String
  reason    String
  status    TarotReportStatus @default(PENDING)
  createdAt DateTime          @default(now())
  user      User              @relation(fields: [userId], references: [id])
  draw      TarotDrawHistory  @relation(fields: [drawId], references: [id])

  @@index([status, createdAt])
}

// 프롬프트 버전 이력 (어드민 관리)
model TarotPromptVersion {
  id          String    @id @default(cuid())
  version     String    @unique // "1.0.0"
  content     String
  isActive    Boolean   @default(false)
  activatedAt DateTime?
  createdBy   String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([isActive])
}

// 카드 컬렉션/도감 — 사용자가 수집한 카드 기록
model TarotCardCollection {
  id           String    @id @default(cuid())
  userId       String
  cardId       String // TarotCard.id 참조
  firstDrawnAt DateTime  @default(now())
  drawCount    Int       @default(1)
  user         User      @relation(fields: [userId], references: [id])
  card         TarotCard @relation(fields: [cardId], references: [id])

  @@unique([userId, cardId])
  @@index([userId])
}

// 모바일 앱 이벤트 트래킹
model TarotAnalyticsEvent {
  id              String   @id @default(cuid())
  userId          String
  event           String // e.g. "draw_start", "ad_earned", "iap_complete"
  properties      Json     @default("{}")
  clientTimestamp DateTime
  createdAt       DateTime @default(now())
  user            User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([event])
  @@index([createdAt])
}

// ─────────────────────────────────────────────
// Admin 보안 모델 (Phase 1)
// ─────────────────────────────────────────────

// 로그인 시도 기록 — 브루트포스 방어용
model AdminLoginAttempt {
  id        String   @id @default(cuid())
  ip        String
  success   Boolean
  createdAt DateTime @default(now())

  @@index([ip, createdAt])
  @@index([createdAt])
}

// 어드민 액션 감사 로그 — 모든 변경 사항 기록
model AdminAuditLog {
  id         String   @id @default(cuid())
  action     String   // "card.update", "prompt.activate", "report.resolve" 등
  targetId   String?
  targetType String?
  before     Json?
  after      Json?
  ip         String?
  userAgent  String?
  createdAt  DateTime @default(now())

  @@index([action, createdAt])
  @@index([createdAt])
}

// 전역 세션 무효화 타임스탬프 — 비밀번호 변경 시 모든 세션 일괄 만료
model AdminSessionConfig {
  id                String   @id @default("singleton")
  invalidatedBefore DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

// ─────────────────────────────────────────────
// FOMO Club (Phase 2) — 감정 집계 + FOMO Index 스냅샷
// docs/FOMO_CLUB.md, docs/FOMO_INDEX.md 참조. 익명 세션 기반, 무가입 허용.
// ─────────────────────────────────────────────

// 익명 감정 투표 — 웹/앱 공통, 1세션 1일 1회
model EmotionVote {
  id        String   @id @default(cuid())
  sessionId String // 익명 세션 (웹: localStorage, 앱: 디바이스 ID)
  userId    String? // 가입자만 (선택)
  emotion   String // "fomo"|"fear"|"regret"|"greed"|"conviction"
  source    String // "web"|"mobile"
  votedDate String // YYYY-MM-DD (1일 1회 제한용)
  createdAt DateTime @default(now())

  @@unique([sessionId, votedDate]) // 1세션 1일 1회
  @@index([votedDate, emotion])
}

// 일일 FOMO Index 스냅샷 — 파이프라인이 산출하여 저장
model FomoIndexSnapshot {
  id            String   @id @default(cuid())
  date          String   @unique // YYYY-MM-DD
  score         Int // 0~100
  state         String // "무관심"|"관망"|"관심"|"FOMO"|"광기"
  marketHeat    Int // 0~30
  communityHeat Int // 0~30
  emotionHeat   Int // 0~30
  whaleHeat     Int // 0~10
  aiSummary     String
  insights      Json // Daily Insights 배너 배열
  prevDayDelta  Int
  avg30Delta    Int
  createdAt     DateTime @default(now())
}

// ─────────────────────────────────────────────
// FOMO Club (P2) — 감정 중심 게임화 데일리 챌린지 + 포인트
// 익명 세션 기반(무가입). 정직한 숫자: 실제 적립 내역만 기록.
// ─────────────────────────────────────────────

// 데일리 챌린지 진행 상태 — 1세션 1일 1챌린지
model DailyChallenge {
  id            String    @id @default(cuid())
  sessionId     String // 익명 세션
  userId        String? // 가입자만 (선택)
  challengeDate String // YYYY-MM-DD (1일 1챌린지)
  status        String // "pending"|"completed"
  completedAt   DateTime?
  createdAt     DateTime  @default(now())

  @@unique([sessionId, challengeDate]) // 1세션 1일 1챌린지
  @@index([challengeDate, status])
}

// 포인트 적립 트랜잭션 로그 — 감정 투표/챌린지 완료. (session, action, refDate) 멱등.
model PointTransaction {
  id        String   @id @default(cuid())
  sessionId String // 익명 세션
  userId    String? // 가입자만 (선택)
  action    String // "emotion_vote"|"challenge_complete"
  amount    Int // 적립 포인트 (POINT_RULES 기준)
  refDate   String // YYYY-MM-DD (멱등 키 + 일자 집계)
  createdAt DateTime @default(now())

  @@unique([sessionId, action, refDate]) // 동일 행동 1일 1회 적립
  @@index([sessionId])
  @@index([userId])
}
