{
  "expo": {
    "name": "FOMO Club",
    "slug": "fomo-club",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "scheme": "fomoclub",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.mlender.fomoclub"
    },
    "android": {
      "package": "com.mlender.fomoclub",
      "edgeToEdgeEnabled": true,
      "permissions": ["android.permission.INTERNET"]
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": ["expo-router"],
    "extra": {
      "apiBaseUrl": ""
    }
  }
}
